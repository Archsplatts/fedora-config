#!/bin/bash

# Afficher le menu et capturer la sÃĐlection
selection=$(echo -e "îŊŦ Dwindle\nîŊŦ Tile\nîž Scroller\nîŊ· Center Tile\nîŊē Vertical Tile\nîŊī Right Tile\nîž Vertical Scroller" | rofi -dmenu -config ~/.config/rofi/layouts.rasi)

# VÃĐrifier si une sÃĐlection a ÃĐtÃĐ faite
if [[ -n "$selection" ]]; then
    # Conversion du nom affichÃĐ vers le nom technique
    layout_name=""
    case "$selection" in
        "îŊŦ Dwindle") layout_name="dwindle" ;;
        "îŊŦ Tile") layout_name="tile" ;;
        #"Monocle") layout_name="monocle" ;;
        #"Grid") layout_name="grid" ;;
        "îž Scroller") layout_name="scroller" ;;
        "îŊ· Center Tile") layout_name="center_tile" ;;
        "îŊē Vertical Tile") layout_name="vertical_tile" ;;
        "îŊī Right Tile") layout_name="right_tile" ;;
        "îž Vertical Scroller") layout_name="vertical_scroller" ;;
